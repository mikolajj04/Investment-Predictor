<Window x:Class="InvestmentPredictor.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestmentPredictor.wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Initial Amount:" />
            <TextBox x:Name="InitialAmountInput" Margin="0,5,0,10"/>
            <TextBlock Text="Market Index:" />
            <ComboBox x:Name="IndexSelector" RenderTransformOrigin="0.5,0.554" />
            <TextBlock TextWrapping="Wrap" Text="Monthly Subsidy"/>
            <TextBox x:Name="MonthlySubsidy" Margin="0,5,0,10"/>
            <TextBlock x:Name="ResultDisplay" FontSize="18" FontWeight="Bold" Margin="0,20,0,0" />
            <Button x:Name="CalculateButton" Content="Calculate Wealth" Click="CalculateButton_Click" Height="23" />
        </StackPanel>

    </Grid>
</Window>
