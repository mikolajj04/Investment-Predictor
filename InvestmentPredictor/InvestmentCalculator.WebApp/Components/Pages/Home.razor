@page "/"
@using InvestmentPredictor
@inject IInvestmentCalculator Calc

<PageTitle>Kalkulator Inwestycyjny</PageTitle>

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Symulator Inwestycji</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Kwota początkowa (PLN)</label>
                        <input type="number" class="form-control" @bind="initialAmount" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Wybierz Indeks</label>
                        <select class="form-select" @bind="chosenIndex">
                            @foreach (var index in Enum.GetValues<MarketIndex>())
                            {
                                <option value="@index">@index</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-success btn-lg w-100" @onclick="Calculate">
                        Oblicz zysk
                    </button>
                </div>

                <div class="col-md-6 d-flex align-items-center justify-content-center">
                    @if (finalResult > 0)
                    {
                        <div class="text-center p-4 border rounded bg-light w-100">
                            <h5 class="text-muted">Przewidywana wartość:</h5>
                            <h2 class="text-success display-4">@finalResult.ToString("C")</h2>
                            <p class="small text-secondary mt-2">*Obliczenia uwzględniają podatek Belki</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <p>Wprowadź dane i kliknij przycisk, aby zobaczyć symulację.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Luźne zmienne do bindowania formularza
    private decimal initialAmount;
    private MarketIndex chosenIndex = MarketIndex.SP500;
    private decimal finalResult;

    private void Calculate()
    {
        // 1. Tworzymy paczkę danych (używamy konstruktora, który masz w .Core)
        // Zakładam, że Twój rekord ma: Index, Initial, Monthly, Interest, Tax, Years
        var inputParams = new CalculatorParams(chosenIndex, initialAmount, 0, 0, 0, 1);

        // 2. Pobieramy stopę zwrotu z kalkulatora (logika z Twojego .Core)
        decimal rate = Calc.GetIndexAnnualReturn(inputParams.chosenIndex);

        // 3. Obliczamy wynik końcowy korzystając z Twojej metody TotalValueAfterTax
        // Używamy słowa 'with', żeby podmienić tylko stopę zwrotu
        var finalParams = inputParams with { annualReturn = rate };

        finalResult = Calc.TotalValueAfterTax(finalParams);
    }
}