@page "/DailyNews"
@using InvestmentPredictor.Core.Entities
@using Microsoft.EntityFrameworkCore
@using InvestmentCalculator.WebApp.Data
@inject AppDbContext DbContext

<PageTitle>Daily Market AI Summary</PageTitle>

<div class="container mt-4">
    <h2 class="fw-bold">🤖 Poranne Podsumowanie AI</h2>
    <p class="text-muted">Syntetyczna analiza globalnego sentymentu rynkowego i makroekonomicznego</p>
    <hr />

    @if (latestSnippet == null)
    {
        <div class="alert alert-warning shadow-sm border-0" role="alert">
            <h5 class="alert-heading">Brak danych!</h5>
            <p>Trwa ładowanie najświeższych danych z bazy lub Nocny Orkiestrator jeszcze nie wygenerował dzisiejszego raportu z powodu przeciążeń sieci.</p>
        </div>
    }
    else
    {
        <div class="card shadow border-0 bg-light mt-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title text-primary mb-0">Sentyment Wall Street</h5>
                    <span class="badge bg-secondary">@latestSnippet.CreatedAt.ToLocalTime().ToString("g")</span>
                </div>

                <p class="card-text mt-3" style="font-size: 1.15rem; line-height: 1.7; white-space: pre-line;">
                    @latestSnippet.Content
                </p>
            </div>
        </div>
    }
</div>

@code {
    private MarketSnippet? latestSnippet;

    protected override async Task OnInitializedAsync()
    {
       
        latestSnippet = await DbContext.MarketSnippets
                                       .OrderByDescending(s => s.CreatedAt)
                                       .FirstOrDefaultAsync();
    }
}